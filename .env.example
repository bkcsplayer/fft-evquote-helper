# =========================
# Required (local + docker)
# =========================

# Database
DB_USER=ev_charger
DB_PASSWORD=your_secure_password
DB_NAME=ev_charger_quote
DB_HOST=db
DB_PORT=5432

# Backend
APP_ENV=development
SECRET_KEY=change_me_to_a_long_random_string
# FRONTEND_URL / ADMIN_URL
# - Docker (docker-compose.yml): will default to http://localhost:7220 and http://localhost:7221
# - Dev (docker-compose.dev.yml): will default to http://localhost:7230 and http://localhost:7231
# You can override by defining these variables in your local `.env` if needed.

# =========================
# Optional
# =========================

# Frontend (optional)
# Enables Google Places Autocomplete for the customer "Install address" field.
VITE_GOOGLE_MAPS_API_KEY=

# Payments
# This project uses **e-transfer** for survey deposits by default (configured in Admin -> Settings -> etransfer_settings).
# Stripe endpoints are disabled (return 410) but variables may still exist in docker-compose for backwards compatibility.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio (optional)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@futurefrontier.ca
SMTP_PASSWORD=xxx
SMTP_FROM_NAME=FutureFrontier Technology
SMTP_FROM_EMAIL=
SMTP_STARTTLS=1
SMTP_USE_SSL=0

# One-time bootstrap admin (recommended for production first run)
# If these are set AND there is no admin user yet, the system will create a super admin once.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=

# Admin login throttling (optional)
ADMIN_LOGIN_WINDOW_SECONDS=300
ADMIN_LOGIN_MAX_ATTEMPTS=8
ADMIN_LOGIN_BLOCK_SECONDS=600
